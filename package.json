{
  "name": "code-kanban",
  "displayName": "Code Kanban Boards",
  "description": "Lightweight kanban boards for your projects, embedded in VSCode.",
  "version": "0.2.3",
  "author": "Marc Sanahuja",
  "license": "MIT",
  "publisher": "marcover9000",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "private": true,
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "kanban",
    "todo",
    "task",
    "board",
    "project-management",
    "agile",
    "productivity",
    "notes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marcover9000/code-kanban.git"
  },
  "bugs": {
    "url": "https://github.com/marcover9000/code-kanban/issues"
  },
  "homepage": "https://github.com/marcover9000/code-kanban#readme",
  "activationEvents": [
    "onStartupFinished",
    "onView:code-kanban.shortcut-view",
    "onView:code-kanban.panel-view"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "code-kanban.edit",
        "displayName": "Code Kanban Boards",
        "selector": [
          {
            "filenamePattern": "*.kanban"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-kanban",
          "title": "Code Kanban",
          "icon": "media/code-kanban-activity-bar.svg"
        }
      ]
    },
    "views": {
      "code-kanban": [
        {
          "id": "code-kanban.shortcut-view",
          "name": "Code Kanban",
          "when": "config.code-kanban.activity-bar-mode == 'shortcut' && config.code-kanban.shortcut-mode.button-location == 'activity-bar'",
          "type": "webview"
        },
        {
          "id": "code-kanban.panel-view",
          "name": "Code Kanban",
          "when": "config.code-kanban.activity-bar-mode == 'panel'",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "code-kanban.new",
        "title": "Code Kanban: Create new Kanban",
        "icon": "$(add)"
      },
      {
        "command": "code-kanban.toggle",
        "title": "Code Kanban: Toggle todo board"
      }
    ],
    "keybindings": [
      {
        "command": "code-kanban.toggle",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Code Kanban",
      "properties": {
        "code-kanban.theme": {
          "title": "Code Kanban Theme",
          "type": "string",
          "default": "system",
          "enum": [
            "dark",
            "light",
            "system"
          ],
          "description": "Switch the theme to dark or light."
        },
        "code-kanban.show-description": {
          "title": "Code Kanban Show Description",
          "type": "boolean",
          "default": "true",
          "description": "Card description is shown."
        },
        "code-kanban.show-task-list": {
          "title": "Code Kanban Show Task List",
          "type": "boolean",
          "default": "true",
          "description": "Card task list is shown."
        },
        "code-kanban.activity-bar-mode": {
          "title": "Activity Bar Mode",
          "type": "string",
          "default": "shortcut",
          "enum": [
            "shortcut",
            "panel"
          ],
          "enumDescriptions": [
            "Activity-bar icon toggles .todo.kanban open/closed in the main editor (no sidebar shown).",
            "Activity-bar icon opens a sidebar rendering the vertical compact board."
          ],
          "description": "Controls how the activity-bar icon behaves."
        },
        "code-kanban.default-lists": {
          "title": "Default Lists",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Backlog",
            "To Do",
            "Doing",
            "Done"
          ],
          "description": "List/column titles used when creating a new kanban file."
        },
        "code-kanban.gitignore-todo": {
          "title": "Add .todo.kanban to .gitignore on creation",
          "type": "boolean",
          "default": true,
          "description": "When enabled (default), creating a new .todo.kanban also appends `*.kanban` to the workspace .gitignore so personal to-dos stay out of source control. Disable if you want to share the kanban file with the team via git."
        },
        "code-kanban.sidebar.show-labels": {
          "title": "Sidebar Show Labels",
          "type": "boolean",
          "default": true,
          "description": "Show card labels as pills in the panel-mode sidebar."
        },
        "code-kanban.sidebar.show-due-date": {
          "title": "Sidebar Show Due Date",
          "type": "boolean",
          "default": true,
          "description": "Show card due date in the panel-mode sidebar."
        },
        "code-kanban.sidebar.show-checkbox-count": {
          "title": "Sidebar Show Checkbox Count",
          "type": "boolean",
          "default": true,
          "description": "Show card checkbox count (e.g. 3/5) in the panel-mode sidebar."
        },
        "code-kanban.shortcut-mode.button-location": {
          "title": "Shortcut Mode: Button Location",
          "type": "string",
          "default": "status-bar",
          "enum": [
            "status-bar",
            "activity-bar"
          ],
          "enumDescriptions": [
            "Show the toggle button in the status bar (bottom). Clean, no visible UI flash when clicked. Recommended.",
            "Show the toggle button as an icon in the activity bar (left). Has a ~50ms visible 'bounce' when clicked (VSCode limitation — the sidebar briefly opens and closes)."
          ],
          "description": "Where to place the toggle button when `activity-bar-mode` is set to 'shortcut'. Does not affect panel mode (in panel mode the activity-bar icon is always shown because it hosts the sidebar view)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build": "NODE_ENV=production webpack --mode production",
    "watch": "NODE_ENV=development webpack --watch --mode development",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "xo --fix src/**/*.ts",
    "test": "xo && vitest run"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/react": "^18.3.12",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.3.5",
    "@types/react-linkify": "^1.0.4",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^11.0.0",
    "@types/vscode": "1.120.0",
    "@vscode/test-electron": "^2.5.2",
    "css-loader": "^7.1.4",
    "glob": "^13.0.6",
    "prettier": "^3.8.4",
    "style-loader": "^4.0.0",
    "styled-components": "^6.4.2",
    "ts-loader": "^9.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-node-externals": "^3.0.0",
    "xo": "^2.0.2"
  },
  "dependencies": {
    "@mojotech/json-type-validation": "^3.1.0",
    "date-fns": "^4.4.0",
    "fuse.js": "^7.4.2",
    "jotai": "^2.20.1",
    "jotai-optics": "^0.4.0",
    "optics-ts": "^2.4.1",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-indiana-drag-scroll": "^3.0.3-alpha",
    "react-linkify": "^1.0.0-alpha",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "react-textarea-autosize": "^8.5.9",
    "uuid": "^14.0.0"
  },
  "xo": {
    "prettier": true,
    "space": 2,
    "ignores": [
      "webpack.config.js",
      "babel.config.js",
      "src/vscode.ts",
      "src/extension.ts"
    ],
    "rules": {
      "max-params": "off",
      "import-x/extensions": "off",
      "@typescript-eslint/no-unsafe-return": "off",
      "@typescript-eslint/no-unsafe-call": "off",
      "@typescript-eslint/no-unsafe-assignment": "off",
      "@typescript-eslint/no-unsafe-argument": "off",
      "no-bitwise": "off",
      "@typescript-eslint/consistent-type-definitions": "off",
      "unicorn/prefer-string-replace-all": "off",
      "n/file-extension-in-import": "off",
      "@typescript-eslint/naming-convention": [
        "error",
        {
          "selector": "objectLiteralProperty",
          "format": []
        },
        {
          "selector": "default",
          "format": [
            "camelCase"
          ],
          "leadingUnderscore": "allow",
          "trailingUnderscore": "allow"
        },
        {
          "selector": "import",
          "format": [
            "camelCase",
            "PascalCase"
          ]
        },
        {
          "selector": "variable",
          "format": [
            "camelCase",
            "UPPER_CASE",
            "PascalCase"
          ],
          "leadingUnderscore": "allow",
          "trailingUnderscore": "allow"
        },
        {
          "selector": "typeLike",
          "format": [
            "PascalCase"
          ]
        }
      ],
      "unicorn/prevent-abbreviations": [
        "error",
        {
          "extendDefaultReplacements": false,
          "replacements": {
            "e": {
              "event": false
            },
            "Props": false
          }
        }
      ],
      "unicorn/filename-case": [
        "error",
        {
          "cases": {
            "camelCase": true,
            "pascalCase": true
          }
        }
      ]
    }
  }
}
